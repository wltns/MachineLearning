- 문자/카테고리 → Classifier
- 숫자/연속값 → Regressor

import numpy as np # linear algebra
import pandas as pd # data processing, CSV file I/O (e.g. pd.read_csv)

from sklearn.preprocessing import StandardScaler, LabelEncoder 
from sklearn.neighbors import KNeighborsRegressor
-----------------------------------------------------------------------------------------
import random
import os

seed = 42
random.seed(seed)
np.random.seed(seed)
os.environ["PYTHONHASHSEED"] = str(seed)
-----------------------------------------------------------------------------------------
train=pd.read_csv('/kaggle/input/competitions/2026-1-ml-3w-p2/train.csv')
test=pd.read_csv('/kaggle/input/competitions/2026-1-ml-3w-p2/test.csv')
sample=pd.read_csv('/kaggle/input/competitions/2026-1-ml-3w-p2/sample_submit.csv')

print(train.head())
print(test.head())
print(sample.head())
-----------------------------------------------------------------------------------------
X_train=train.drop('price',axis=1)
y_train=train['price'] # 데이터를 꺼낼 때 []
X_test=test.copy()

a = LabelEncoder()
X_train['model']=a.fit_transform(X_train['model']) # 이 값은 문자값이므로 인코딩 해야함
X_test['model']=a.transform(X_test['model']) # moder열만 인코딩 
-----------------------------------------------------------------------------------------
scaler = StandardScaler()

X_train_std=scaler.fit_transform(X_train)
X_test_std=scaler.transform(X_test)
-----------------------------------------------------------------------------------------
# 성능 개선된 knn 모델을 생성하고 학습하는 셀 
model = KNeighborsRegressor(
    n_neighbors=7,
    weights='distance',
    p=1
)

model.fit(X_train_std, y_train)
-----------------------------------------------------------------------------------------
# 테스트 데이터에 대해 예측을 수행하는 셀 

y_pred = model.predict(X_test_std)

print(y_pred[:10])
-----------------------------------------------------------------------------------------
# 예측 결과를 sample submission 형식에 맞게 저장하는 셀 
sample['price'] = y_pred
sample.to_csv('submission.csv', index=False)

print(sample.head())
