# 라이브러리 
import numpy as np # linear algebra
import pandas as pd # data processing, CSV file I/O (e.g. pd.read_csv)

from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.neighbors import KNeighborsClassifier

# 랜덤시드 고정 
import random
import os 

seed=42
random.seed(seed)
np.random.seed(seed)
os.environ['PYTHONHASHSEED']=str(seed)

# train, test, sample submission 데이터를 불러옴
train = pd.read_csv('/kaggle/input/competitions/2026-1-ml-3w-p1/train.csv')
test = pd.read_csv('/kaggle/input/competitions/2026-1-ml-3w-p1/test.csv')
sample = pd.read_csv('/kaggle/input/competitions/2026-1-ml-3w-p1/sample_submit.csv')

print(train.head())
print(test.head())
print(sample.head())

# 학습 데이터에서 입력값과 정답값을 나누는 셀
X_train = train.drop('label', axis=1)
y_train = train['label'] # label의 열을 y_trian에 저장 

X_test = test.copy()

# 카테고리의 실수화 
le = LabelEncoder()
y_train_encoded = le.fit_transform(y_train)

# 확인 
print(le.classes_)
print(X_train.shape)
print(y_train.shape)
print(X_test.shape)

# 입력 데이터를 표준화하여 knn의 성능을 높이는 셀 
scaler = StandardScaler()

X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# 성능 개선된 knn 모델을 생성하고 학습하는 셀 
model = KNeighborsClassifier(
    n_neighbors=7,
    weights='distance', # 거리가 가까운 것에 가중치
    p=1 # 맨하탄 거리, P=2는 유클리드 거리 (직선) 
)

model.fit(X_train_scaled, y_train_encoded)

# 테스트 데이터에 대해 예측을 수행하는 셀 
y_pred_encoded = model.predict(X_test_scaled)
y_pred = le.inverse_transform(y_pred_encoded)

print(y_pred[:10])

# 예측 결과를 sample submission 형식에 맞게 저장하는 셀 
sample['label'] = y_pred
sample.to_csv('submission.csv', index=False)

print(sample.head())
