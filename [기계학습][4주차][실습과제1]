# 라이브러리 불러오기
import numpy as np # linear algebra
import pandas as pd # data processing, CSV file I/O (e.g. pd.read_csv)

# 랜덤시드 고정
import random
import os

seed = 42

random.seed(seed)
np.random.seed(seed)
os.environ["PYTHONHASHSEED"] = str(seed)

# 데이터 불러오기 및 데이터 형태 확인(어디를 수치화 해야하는지)
X_train=pd.read_csv('/kaggle/input/competitions/2026-1-ml-4w-p1/trainX.csv')
y_train=pd.read_csv('/kaggle/input/competitions/2026-1-ml-4w-p1/trainY.csv')
X_test=pd.read_csv('/kaggle/input/competitions/2026-1-ml-4w-p1/testX.csv')
submit=pd.read_csv('/kaggle/input/competitions/2026-1-ml-4w-p1/submit.csv')
print(X_train.head())
print(y_train.head())
print(X_test.head())
print(submit.head())

# 표준화, 인코딩, 로지스틱 회귀 라이브러리 불러오기 + 데이터 수치화 
# 이미 x_train, y_train, x_test가 나눠져 있는 데이터이므로 분할은 필요 x
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.linear_model import LogisticRegression

y=y_train['Category']
a=LabelEncoder()
y_le=a.fit_transform(y)

sc=StandardScaler()
X_train_std=sc.fit_transform(X_train)
X_test_std=sc.transform(X_test)

# 로지스틱 회귀 모델 만들기
# 규제의 정도를 변화 시키는 하이퍼 파라미터 값을 조정하며, 제일 효율 좋은 c 값을 구하기
model = LogisticRegression(
    C=10,
    max_iter=2000,
    random_state=42
)

# 모델 학습
model.fit(X_train_std, y_le)

# 테스트 데이터 예측
y_pred_le = model.predict(X_test_std)

# 숫자 예측값을 다시 문자열로 바꾸기
y_pred = a.inverse_transform(y_pred_le)

# 제출 파일에 예측값 넣기
submit['Category'] = y_pred

# 제출 파일 저장
submit.to_csv('/kaggle/working/submission.csv', index=False)
print(submit.head())

